rules_version = '2';

// BookNest Firebase Storage rules (Lab 3 advanced feature).
// Covers are publicly readable so any student can see them in the list, but
// only authenticated users may upload, and only image files up to 5 MB.
service firebase.storage {
  match /b/{bucket}/o {
    match /book_covers/{imageId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
